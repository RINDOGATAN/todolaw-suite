# AI SENTINEL local development configuration (cp .env.example .env.local).
# The sovereign self-host bundle has its own example: deploy/sovereign/.env.example.
# Placeholders only. Never commit real values.

# Database (NB: the Prisma datasource reads ais_DATABASE_URL, a Vercel-scoped name)
ais_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aisentinel?schema=public"

# NextAuth (dev server runs on port 3003)
NEXTAUTH_URL="http://localhost:3003"
NEXTAUTH_SECRET="your-secret-here"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email (Resend, optional, magic-link login)
RESEND_API_KEY=""
EMAIL_FROM="noreply@todo.law"

# Auth switches
# Set to "true" to disable the passwordless dev/local credentials provider.
DISABLE_DEV_AUTH=""
# Cross-app SSO provider (*.todo.law cloud only). Default: enabled on Vercel,
# disabled everywhere else. Set "true"/"false" to override.
CROSS_LOGIN_ENABLED=""
# Shared secret for cross-login magic-link JWTs (cloud only).
CROSS_LOGIN_SECRET=""

# Seeding
# "true" seeds the demo org/users/sample data. Unset = content-only seed.
DEMO_SEED=""

# Offline skill licensing. Ed25519 public key (PEM, SPKI) of the TODO.LAW
# storefront signing keypair — the SAME key across the whole app family
# (Dealroom, DPO Central, AI Sentinel). Licence files uploaded on
# /governance/skills are verified against it. Unset = a placeholder that
# rejects every licence.
# Multi-line PEM: keep the quotes and the \n escapes, or use a literal block.
SKILL_SIGNING_PUBLIC_KEY=""

# Stable identifier of THIS installation for licence activation limits.
# Optional — defaults to a machine-fingerprint-derived id (hostname + MAC).
# Set it explicitly on serverless/containers, where hostname/MAC change:
#   openssl rand -hex 16   (prefix with "inst_" by convention)
# AISENTINEL_INSTANCE_ID=""

# Premium entitlement gates. Unset: skills are free whenever Stripe is off
# (the hosted unpaywalled-demo posture). Set "false" to enforce entitlements
# without Stripe — offline licence files become the purchase path (sovereign
# posture). Set "true" to force-free even with Stripe on.
NEXT_PUBLIC_ALL_SKILLS_FREE=""

# Stripe (optional - for premium features)
NEXT_PUBLIC_STRIPE_ENABLED=""
NEXT_PUBLIC_SELF_SERVICE_UPGRADE=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs (created in Stripe Dashboard)
# All premium skills are €9/mo — set STRIPE_PRICE_ID to share a single price
# (same env var used by DPO Central), or override per-package below.
STRIPE_PRICE_ID=""
STRIPE_PRICE_ID_USD=""
STRIPE_PRICE_CONFORMITY=""
STRIPE_PRICE_BIAS=""
STRIPE_PRICE_SHADOW=""
STRIPE_PRICE_VENDOR_CATALOG=""

# Vendor.Watch catalog sync (weekly cron on the cloud)
VENDORWATCH_CATALOG_API_URL="https://vendorwatch.todo.law/api/catalog/sync"
VENDORWATCH_CATALOG_API_KEY=""
# Comma-separated API keys accepted by POST /api/import/portfolio-vendors
VW_IMPORT_API_KEYS=""

# Dealroom Expert Directory (optional; mock directory when unset)
DEALROOM_API_URL=""
DEALROOM_API_KEY=""

# Vercel Cron Secret (protects /api/cron/sync-catalog)
CRON_SECRET=""

# Admin emails (comma-separated; platform-admin tRPC procedures)
ADMIN_EMAILS=""

# White-label brand (all optional; defaults in src/config/brand.ts).
# NEXT_PUBLIC_* values are baked into the client bundle at BUILD time.
NEXT_PUBLIC_BRAND_NAME=""
NEXT_PUBLIC_BRAND_TAGLINE=""
NEXT_PUBLIC_BRAND_DESCRIPTION=""
NEXT_PUBLIC_COMPANY_NAME=""
NEXT_PUBLIC_COMPANY_WEBSITE=""
NEXT_PUBLIC_TERMS_URL=""
NEXT_PUBLIC_PRIVACY_URL=""
NEXT_PUBLIC_SUPPORT_EMAIL=""
NEXT_PUBLIC_SECURITY_EMAIL=""
NEXT_PUBLIC_SITE_URL=""
# AGPL section 13: complete corresponding source. Point at YOUR fork if you
# deploy a modified version; defaults to the upstream repository.
NEXT_PUBLIC_SOURCE_URL="https://github.com/RINDOGATAN/aisentinel"
NEXT_PUBLIC_LICENSE_URL=""
# DPO Central deep links (empty string hides them; unset keeps the default)
NEXT_PUBLIC_DPO_CENTRAL_URL=""
# Convenience: sets primary + accent in one variable
NEXT_PUBLIC_BRAND_ACCENT=""
NEXT_PUBLIC_BRAND_LOGO_URL=""
# Fine-grained overrides (win over BRAND_ACCENT / BRAND_LOGO_URL)
NEXT_PUBLIC_LOGO_PATH=""
NEXT_PUBLIC_FAVICON_PATH=""
NEXT_PUBLIC_COLOR_PRIMARY=""
NEXT_PUBLIC_COLOR_PRIMARY_FG=""
NEXT_PUBLIC_COLOR_BACKGROUND=""
NEXT_PUBLIC_COLOR_CARD=""
NEXT_PUBLIC_COLOR_ACCENT=""

# Set to "true" only once the source repo is PUBLIC; until then the
# /licenses page offers the corresponding source on request instead of a 404 link.
NEXT_PUBLIC_SOURCE_PUBLIC=false
