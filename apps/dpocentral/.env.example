# Development defaults — match the dev database in docker-compose.yml.
# For self-hosted production use deploy/sovereign/.env.example instead.

# Database
DATABASE_URL="postgresql://dpocentral:dpocentral_dev@localhost:5434/dpocentral?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="your-secret-here"   # openssl rand -base64 32

# Sign-in methods (all optional; enable at least one)
# Local passwordless login — dev/LAN only, never on the public internet:
NEXT_PUBLIC_LOCAL_AUTH_ENABLED="true"
# Google OAuth (optional):
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Email magic links via Resend (optional):
RESEND_API_KEY=""

# Auth cookie scope. Leave unset for host-only cookies (correct for almost
# every deployment). Set to a parent domain (e.g. ".example.com") only for
# multi-subdomain single sign-on.
# AUTH_COOKIE_DOMAIN=""

# Platform admin (comma-separated emails; unset = no platform admins)
ADMIN_EMAILS=""

# DSAR auto-redaction cron — the endpoint refuses to run without this.
# Call GET /api/cron/dsar-redaction with "Authorization: Bearer $CRON_SECRET".
CRON_SECRET=""

# Vendor.Watch catalog sync. DPO owns its own DB and pulls the global
# vendor catalog from vendor.watch's /catalog/sync API over HTTP.
# Cloud: run `npm run db:sync-vendor-catalog` on a schedule.
# The KEY must be a member of cloud vendor.watch's CATALOG_API_KEYS, and is
# DISTINCT from VW_IMPORT_API_KEYS (the portfolio-push key). Do not reuse one
# for the other.
VENDORWATCH_CATALOG_API_URL="https://vendorwatch.todo.law/api/catalog/sync"
VENDORWATCH_CATALOG_API_KEY=""

# Cross-app portfolio import (Part B). vendor.watch pushes a user's portfolio
# to DPO's /api/import endpoints over HTTP, keyed by email. Comma-separated
# list of accepted x-api-key values. Must match vendor.watch's
# DPC_IMPORT_API_KEY. Leave empty to reject all imports.
DPC_IMPORT_API_KEYS=""
