# DPO Central — sovereign bundle configuration.
#   cp .env.example .env    then fill the three required values.
# chmod 600 .env — it holds the auth secret and the DB password.

# ---- Required ---------------------------------------------------------------
# openssl rand -hex 24
POSTGRES_PASSWORD=
# openssl rand -base64 32
NEXTAUTH_SECRET=
# The origin users type into the browser. Localhost default; for LAN/VPS use
# the TLS profile and set https://<TLS_DOMAIN> here.
PUBLIC_URL=http://localhost:8485

# ---- Network ----------------------------------------------------------------
# 127.0.0.1 = this machine only (default). 0.0.0.0 = office LAN (firewall it).
BIND_ADDR=127.0.0.1
# 8485 is the suite convention for DPO Central; change if it collides.
PORT=8485

# ---- Brand (build-time: docker compose up -d --build app after changing) ----
NEXT_PUBLIC_BRAND_NAME=DPO Central
# Accent/primary color, e.g. #53aecc (the default). Sets --primary + --accent.
NEXT_PUBLIC_BRAND_ACCENT=
# Absolute URL or /path under public/. Empty = the stock logo.
NEXT_PUBLIC_BRAND_LOGO_URL=

# ---- Auth posture (build-time) ----------------------------------------------
# Local credentials login (email, no password, no external services). This is
# the sovereign default — the box is behind the firm's own network.
NEXT_PUBLIC_LOCAL_AUTH_ENABLED=true
# Magic-link email login requires RESEND_API_KEY (a cloud API) — cloud tier.
NEXT_PUBLIC_EMAIL_AUTH_ENABLED=false
# Google OAuth requires GOOGLE_CLIENT_ID/SECRET — cloud tier.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
# Host-only session cookies are the default (leave empty). Set a parent
# domain only for multi-subdomain SSO — cloud deployments set .todo.law.
AUTH_COOKIE_DOMAIN=
# Comma-separated emails allowed into /admin (platform admin). Optional.
ADMIN_EMAILS=
# DSAR retention auto-redaction (the redaction-cron service calls the app
# daily with this). openssl rand -hex 32. Empty = redaction disabled — the
# endpoint fails closed and the cron service logs a warning.
CRON_SECRET=

# ---- The one LLM door (optional) ---------------------------------------------
# Any OpenAI-compatible endpoint: LQ.AI's gateway, LiteLLM, etc.
# e.g. http://host.docker.internal:8001 — empty disables AI narratives cleanly.
LLM_GATEWAY_URL=
LLM_GATEWAY_KEY=
# e.g. ollama-local/qwen3:8b
LLM_MODEL_ALIAS=

# ---- Premium skills (offline licences — the sovereign purchase path) ---------
# Skills bought on TODO.LAW arrive as Ed25519-signed .license.json files;
# owners/admins upload them on /privacy/skills. No Stripe, no phone-home.
# Ed25519 public key (PEM, SPKI) of the storefront signing keypair — the same
# key across the whole app family. Empty = every licence is rejected.
SKILL_SIGNING_PUBLIC_KEY=
# Stable id of THIS installation for licence activation limits. Set it in
# Docker (the container's virtual MAC can change across recreates):
#   echo "inst_$(openssl rand -hex 16)"
DPO_INSTANCE_ID=

# ---- Stripe (cloud tier — leave empty in the sovereign posture) --------------
NEXT_PUBLIC_STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Optional cloud mailer (only if EMAIL_AUTH is enabled) --------------------
RESEND_API_KEY=

# ---- TLS profile (LAN/VPS): docker compose --profile tls up -d ---------------
TLS_DOMAIN=

# ---- Vendor catalog refresh (optional, operator-triggered) -------------------
# DPO owns its own database. The global vendor catalog is pulled from
# vendor.watch's /catalog/sync API over HTTP, not from a shared DB. On a
# self-host box this is a one-off: fill these, run
#   docker compose exec app npm run db:sync-vendor-catalog
# to refresh the local catalog, then leave them empty and stay air-gapped.
# Cloud runs the same sync on a schedule; self-host runs it on demand.
# The KEY must be a member of cloud vendor.watch's CATALOG_API_KEYS, and is
# DISTINCT from VW_IMPORT_API_KEYS (the portfolio-push key) — never reuse one
# for the other.
VENDORWATCH_CATALOG_API_URL=
VENDORWATCH_CATALOG_API_KEY=

# ---- Cross-app portfolio import (optional) -----------------------------------
# vendor.watch can push a user's portfolio into DPO's /api/import endpoints
# over HTTP, keyed by email. Comma-separated list of accepted x-api-key
# values; must match vendor.watch's DPC_IMPORT_API_KEY. Self-host default is
# empty (imports rejected) — set it only if you run vendor.watch alongside.
DPC_IMPORT_API_KEYS=

# ---- Backups ------------------------------------------------------------------
# Required by backup.sh/restore.sh (openssl AES-256).
BACKUP_PASSPHRASE=
# Optional rclone remote for off-machine copies, e.g. b2:nel-backups
BACKUP_RCLONE_REMOTE=
