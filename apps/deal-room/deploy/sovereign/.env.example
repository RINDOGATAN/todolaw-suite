# Dealroom — sovereign bundle configuration.
#   cp .env.example .env && chmod 600 .env
# Required: POSTGRES_PASSWORD, NEXTAUTH_SECRET, PUBLIC_URL. Everything else
# is optional cloud-tier plumbing that the sovereign posture leaves off.

# ── Required ────────────────────────────────────────────────────────────────
# openssl rand -base64 24
POSTGRES_PASSWORD=
# openssl rand -base64 32   (rotating this signs everyone out — JWT sessions)
NEXTAUTH_SECRET=
# The URL users type. localhost default; for LAN/TLS see README "Hardening".
PUBLIC_URL=http://localhost:8486

# ── Bind/port ───────────────────────────────────────────────────────────────
# 127.0.0.1 = this machine only (default). 0.0.0.0 = office LAN (firewall it).
#BIND_ADDR=127.0.0.1
#PORT=8486

# ── Posture (NEXT_PUBLIC_* are baked in at BUILD time — after changing,
#    run: docker compose up -d --build app) ─────────────────────────────────
# Local credentials login (email-only, no password, no mailer). The whole
# point of the sovereign posture; never enable on an internet-facing box.
#NEXT_PUBLIC_LOCAL_AUTH_ENABLED=true
# All premium skills unlocked (no Stripe marketplace locally).
#NEXT_PUBLIC_FREE_TRIAL_ALL_SKILLS=true
# Host-only auth cookie (empty). Cloud sets .todo.law for cross-app SSO.
#AUTH_COOKIE_DOMAIN=
# AGPL corresponding-source offer shown on /licenses (§13). Defaults to the
# public repo; override to point network users at your own published source.
NEXT_PUBLIC_SOURCE_URL=https://github.com/RINDOGATAN/deal-room

# ── Brand (optional; build-time) ────────────────────────────────────────────
#NEXT_PUBLIC_BRAND_NAME=Northend Law Dealroom
#NEXT_PUBLIC_BRAND_ACCENT=#53aecc
#NEXT_PUBLIC_BRAND_LOGO_URL=/logo.svg

# ── Optional cloud-tier services (all degrade gracefully when empty) ────────
# Outbound mail: deal invitations, signing notifications, magic-link and the
# admin/supervisor portals' login emails. Empty = skipped with a log line.
#RESEND_API_KEY=
#EMAIL_FROM=noreply@your-firm.example
# Google OAuth sign-in. NEXT_PUBLIC_GOOGLE_CLIENT_ID feeds the sign-in
# button and is baked in at BUILD time (rebuild after changing); the other
# two are runtime. Optional — all empty = no Google login.
#NEXT_PUBLIC_GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
# Stripe (skill marketplace billing — cloud tier).
#STRIPE_SECRET_KEY=
#STRIPE_WEBHOOK_SECRET=
#STRIPE_PRICE_ID=
#STRIPE_PRICE_ID_USD=
# Dealroom Cloud Intelligence (biases, quality scoring, certification).
#DEALROOM_CLOUD_API_URL=
#DEALROOM_CLOUD_API_KEY=
# Gavel dispute resolution + Firmas mobile signing (sibling apps).
#GAVEL_API_URL=
#GAVEL_API_KEY=
#GAVEL_WEBHOOK_SECRET=
#FIRMAS_BASE_URL=
#FIRMAS_ISSUER=
# Firmas signing-page links shown to users (optional; BUILD time — rebuild
# after changing). Empty = https://www.firmas.io.
#NEXT_PUBLIC_FIRMAS_BASE_URL=
# Signed skill downloads / package signature verification.
#DOWNLOAD_TOKEN_SECRET=
#SKILL_SIGNING_PUBLIC_KEY=
# Guard for GET /api/cron/daily (signing reminders/expiry — see README).
#CRON_SECRET=
# Stable licensing-fingerprint ID across container recreations (optional;
# e.g. `openssl rand -hex 8`). Empty = generated fresh per process.
#DEAL_ROOM_INSTANCE_ID=

# ── TLS profile (README "Hardening") ────────────────────────────────────────
#TLS_DOMAIN=dealroom.firm.example

# ── Backups ─────────────────────────────────────────────────────────────────
# Passphrase for AES-256 backup encryption (backup.sh / restore.sh).
BACKUP_PASSPHRASE=
# Optional off-machine push, any rclone remote (e.g. "b2:nel-backups").
#BACKUP_RCLONE_REMOTE=

# Set to "true" only once the source repo is PUBLIC; until then the
# /licenses page offers the corresponding source on request instead of a 404 link.
NEXT_PUBLIC_SOURCE_PUBLIC=false
