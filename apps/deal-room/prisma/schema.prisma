model AgentDealRoom {
  id                   String          @id @default(cuid())
  dealRoomId           String?         @unique
  negotiationToken     String          @unique
  initiatorCustomerId  String
  respondentCustomerId String?
  initiatorPlaybookId  String
  respondentPlaybookId String?
  status               AgentDealStatus @default(PENDING_RESPONDENT)
  contractType         String
  governingLaw         GoverningLaw
  contractLanguage     String          @default("en")
  dealName             String
  initiatorCompany     String
  initiatorEmail       String
  respondentCompany    String?
  respondentEmail      String?
  negotiationLog       Json?
  failureReason        String?
  resolvedAt           DateTime?
  createdAt            DateTime        @default(now())

  // Attorney attestation (Phase 2)
  attestingBarNumber    String? // e.g. "CA-123456"
  attestingAttorneyName String? // e.g. "John Doe, Esq."

  dealRoom           DealRoom?     @relation(fields: [dealRoomId], references: [id])
  initiatorPlaybook  Playbook      @relation("initiatorPlaybook", fields: [initiatorPlaybookId], references: [id])
  respondentPlaybook Playbook?     @relation("respondentPlaybook", fields: [respondentPlaybookId], references: [id])
