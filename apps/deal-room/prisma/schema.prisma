}

// ============================================================
// PLAYBOOKS (Agent Negotiation Preferences)
// ============================================================

model Playbook {
  id               String       @id @default(cuid())
  customerId       String
  name             String
  contractType     String
  governingLaw     GoverningLaw
  contractLanguage String       @default("en")
  isDefault        Boolean      @default(false)
  isActive         Boolean      @default(true)
  metadata         Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  customer            Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  entries             PlaybookEntry[]
  initiatedAgentDeals AgentDealRoom[] @relation("initiatorPlaybook")
  respondedAgentDeals AgentDealRoom[] @relation("respondentPlaybook")

  @@unique([customerId, name])
  @@map("playbooks")
}

model PlaybookEntry {
  id                String   @id @default(cuid())
  playbookId        String
  clauseId          String
  preferredOptionId String
  priority          Int      @default(3)
  flexibility       Int      @default(3)
  isRedLine         Boolean  @default(false)
  acceptableOptions String[]
  notes             String?  @db.Text

  playbook Playbook @relation(fields: [playbookId], references: [id], onDelete: Cascade)

  @@unique([playbookId, clauseId])
  @@map("playbook_entries")
}

