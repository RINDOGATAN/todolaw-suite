// ============================================================
// REVENUE EVENTS (Phase 2)
// ============================================================

model RevenueEvent {
  id               String    @id @default(cuid())
  skillPackageId   String
  authorId         String
  eventType        String // SUBSCRIPTION_PAYMENT | DEAL_COMPLETION
  grossAmount      Int // cents
  platformAmount   Int // todo.law share
  authorAmount     Int // author share
  currency         String    @default("eur")
  stripeTransferId String?
  settledAt        DateTime?
  createdAt        DateTime  @default(now())

  skillPackage SkillPackage @relation(fields: [skillPackageId], references: [id])

  @@map("revenue_events")
}

// Idempotency ledger for Stripe webhooks. The webhook handler
// claims an event by inserting its event.id here; concurrent or
// retried deliveries hit the unique constraint and short-circuit
// without re-running the handler. If the handler errors, the row
// is removed so Stripe's next retry can re-claim and re-process.
model StripeWebhookEvent {
  id          String   @id // Stripe event.id (e.g. evt_1A2B3C...)
  eventType   String
  processedAt DateTime @default(now())

  @@map("stripe_webhook_events")
}

// Fixed-bucket rate-limit counter. Replaces the in-memory Map
// store, which was per-process (broken across Vercel cold-starts
// and concurrent instances) and non-atomic (concurrent requests
// could both pass a length-check and both push). The key encodes
// (customerId, bucket-name, window-start-ms); atomic upsert with
// `count: { increment: 1 }` is durable and race-free at the DB.
model RateLimitCounter {
  key       String   @id // e.g. "{customerId}:a2a:premium:1714377600000"
  count     Int      @default(0)
  expiresAt DateTime

  @@index([expiresAt])
  @@map("rate_limit_counters")
}

// Cache for client-supplied Idempotency-Key headers on agent POST
// endpoints. Same key + same customer within the TTL window replays
// the original 2xx response instead of re-executing the handler —
// matches Stripe's idempotency contract. Composite primary key on
// (customerId, key) so different customers can reuse key values.
model IdempotencyRecord {
  customerId   String
  key          String
  method       String
  path         String
  status       Int
  responseBody String   @db.Text
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@id([customerId, key])
  @@index([expiresAt])
  @@map("idempotency_records")
}

// ============================================================
// WEBHOOKS (Phase 4)
// ============================================================

model WebhookEndpoint {
  id         String   @id @default(cuid())
  customerId String
  url        String
  secret     String // HMAC-SHA256 signing secret
  events     String[] // subscribed event types
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("webhook_endpoints")
}

// ============================================================
// AGENT DISPUTES / GAVEL INTEGRATION (Phase 6)
// ============================================================

model AgentDispute {
  id              String    @id @default(cuid())
  agentDealRoomId String    @unique
  gavelCaseId     String    @unique
  escrowAmount    Int? // USDC smallest unit
  status          String // PENDING | IN_ARBITRATION | RESOLVED
  resolutionData  Json?
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())

  agentDealRoom AgentDealRoom @relation(fields: [agentDealRoomId], references: [id])

  @@map("agent_disputes")
}

// ============================================================
// STARTUP JOURNEY (guided launch experience for US startups)
// ============================================================

enum StartupJourneyStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model StartupJourney {
  id     String               @id @default(cuid())
  userId String
  status StartupJourneyStatus @default(IN_PROGRESS)

  // Company profile (shared across all deals in this journey)
  companyName    String
  companyAddress String?
  state          String  @default("DELAWARE") // US state, free-text for phase 2
  entityType     String  @default("C_CORP") // C_CORP | LLC (future)

  // Capitalization defaults
  authorizedShares  Int      @default(10000000)
  parValue          Decimal  @default(0.00001) @db.Decimal(12, 8)
  optionPoolPercent Decimal? @db.Decimal(5, 2)

  // Per-step state: { foundation: { status, completedAt, supervisorId?, ... }, equity: { ... }, ... }
  stepStatuses Json @default("{}")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  user      User             @relation(fields: [userId], references: [id])
  founders  JourneyFounder[]
  dealRooms DealRoom[]

  @@index([userId])
  @@map("startup_journeys")
}

model JourneyFounder {
  id             String   @id @default(cuid())
  journeyId      String
  name           String
  email          String
  title          String?
  sharesIssued   Int?
  equityPercent  Decimal? @db.Decimal(5, 2)
  vestingYears   Int?     @default(4)
  cliffMonths    Int?     @default(12)
  isIncorporator Boolean  @default(false)
  isPrimary      Boolean  @default(false)
  createdAt      DateTime @default(now())

  journey StartupJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@index([journeyId])
  @@map("journey_founders")
}
