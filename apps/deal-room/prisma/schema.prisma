model LawyerProfile {
  id            String         @id @default(cuid())
  userId        String         @unique
  bio           String?        @db.Text
  jurisdictions GoverningLaw[]
  languages     String[] // ISO 639-1 codes: ["en", "es"]
  isPublished   Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Cross-product directory fields
  title                  String? // e.g. "Partner, Data Protection"
  expertTypes            String[] // controlled vocabulary: TECHNICAL, DEPLOYMENT — validated at app layer (LEGAL retired 2026-07; legacy rows filtered out by the experts API)
  specializations        String[] // controlled vocabulary, validated at app layer
  certifications         String[] // e.g. ["CIPP_E", "CISSP"]
  countryCode            String? // ISO 3166-1 alpha-2 (where they are based)
  city                   String?
  jurisdictionsCovered   String[] // broader than GoverningLaw, e.g. ["EU", "UK", "US", "CA"]
  contactUrl             String?
  acceptingClients       Boolean  @default(true)
  stripeConnectAccountId String? // Stripe Connect account for revenue share (Phase 2)
  notifyEmails           String[] @default([]) // additional inboxes BCC'd on contact requests; not exposed publicly

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("lawyer_profiles")
}

enum RecommendationRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  COMPLETED
  CANCELLED
}

model RecommendationRequest {
  id           String                      @id @default(cuid())
  requesterId  String?
  lawyerId     String
  contractType String
  governingLaw GoverningLaw?
  message      String?                     @db.Text
  status       RecommendationRequestStatus @default(PENDING)
  vettingId    String?
  respondedAt  DateTime?
  expiresAt    DateTime // Set at creation. PENDING + past expiresAt = stale; mutations refuse.
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  // External request tracking (from DPO Central, AI Sentinel, etc.)
  sourceApp                String?
  sourceCustomerId         String?
  externalRequesterName    String?
  externalRequesterEmail   String?
  externalRequesterCompany String?

  requester      User?          @relation("RequestsSent", fields: [requesterId], references: [id])
  lawyer         User           @relation("RequestsReceived", fields: [lawyerId], references: [id])
  vetting        LawyerVetting? @relation(fields: [vettingId], references: [id])
  sourceCustomer Customer?      @relation(fields: [sourceCustomerId], references: [id], onDelete: SetNull)

  @@map("recommendation_requests")
}

