// ============================================================
// CLAUSE MAPPINGS (Cross-jurisdiction clause equivalences)
// ============================================================

model ClauseMapping {
  id               String   @id @default(cuid())
  familyKey        String // e.g., "FOUNDERS"
  sourceClauseId   String // clauseId from source template (e.g., "equity-split")
  targetClauseId   String // clauseId from target template (e.g., "distribucion-participaciones")
  sourceTemplateId String
  targetTemplateId String
  mappingType      String // "equivalent", "split", "merged", "new"
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  sourceTemplate ContractTemplate @relation("sourceMappings", fields: [sourceTemplateId], references: [id])
  targetTemplate ContractTemplate @relation("targetMappings", fields: [targetTemplateId], references: [id])

  @@unique([familyKey, sourceClauseId, targetClauseId])
  @@map("clause_mappings")
}

// ============================================================
// API KEYS (Agent Authentication)
// ============================================================

model ApiKey {
  id         String    @id @default(cuid())
  customerId String
  name       String
  keyHash    String    @unique
  keyPrefix  String
  scopes     String[]
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  expiresAt  DateTime?
