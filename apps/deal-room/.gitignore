# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem
/sample-pdfs
/e2e/output/
/reference/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!deploy/sovereign/.env.example
deploy/sovereign/backups/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
.env*.local
dpa-purge-test-deals.cjs

# Local scratch screenshots
/sshots/

# Internal dev context (like DPO Central) — kept locally, never shipped in the downloadable bundle
/CLAUDE.md
