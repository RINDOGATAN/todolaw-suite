{
  "name": "deal-room",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "bin": {
    "deal-room": "./cli/index.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma migrate deploy && prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "check:api": "node scripts/check-api-error-handling.mjs",
    "check:skills": "node scripts/check-skills.mjs",
    "skills:manifest": "node scripts/skills-sync.mjs manifest",
    "skills:diff": "node scripts/skills-sync.mjs diff",
    "db:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "skill:install": "tsx cli/commands/skill-install.ts",
    "skill:list": "tsx cli/commands/skill-list.ts",
    "skill:verify": "tsx cli/commands/skill-verify.ts",
    "skill:activate": "tsx cli/commands/skill-activate.ts",
    "skill:package": "tsx cli/commands/skill-package.ts",
    "skill:package-all": "tsx cli/commands/skill-package-all.ts",
    "skill:deactivate": "tsx cli/commands/skill-deactivate.ts",
    "license:fingerprint": "tsx cli/commands/license-fingerprint.ts",
    "keygen": "tsx cli/commands/keygen.ts",
    "admin:create": "tsx cli/commands/admin-create.ts",
    "supervisor:create": "tsx cli/commands/supervisor-create.ts",
    "deal:simulate": "tsx --env-file=.env.local scripts/simulate-deals.ts",
    "skill:build": "tsx scripts/build-skill-packages.ts",
    "skill:upload": "tsx --env-file=.env.local scripts/upload-skill-packages.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
