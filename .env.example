# todo.law suite — prebuilt-image install (docker-compose.yml).
# Copy to .env, fill the values, then: docker compose up -d
#
# Apps:  DPO Central  http://localhost:8485
#        Dealroom     http://localhost:8486
#        AI Sentinel  http://localhost:8487

# Which release to run. Pin a version (e.g. v0.1.1) for a reproducible install;
# "latest" always pulls the newest published images.
TODOLAW_VERSION=latest

# Database passwords (any strong strings; they only live inside this stack).
DPO_DB_PASSWORD=
DEAL_DB_PASSWORD=
AIS_DB_PASSWORD=

# Session signing secret. Generate one: openssl rand -base64 32
NEXTAUTH_SECRET=

# Cross-app bridge (optional). Set the SAME strong string here to turn on the
# unified DPIA + AI-Act view between DPO Central and AI Sentinel. Leave empty to
# keep them independent. Generate: openssl rand -hex 24
BRIDGE_API_KEY=

# Only used by `./suite.sh backup` to encrypt backups (not needed for a plain
# `docker compose up`). Keep a copy — you need it to restore. Generate: openssl rand -base64 24
BACKUP_PASSPHRASE=

# Workspace passphrase (optional): when set, every browser is asked for it once
# before anyone can sign in to the apps. A speed bump against casual snooping on
# the computer — the real protection is the machine's own login + disk
# encryption (FileVault/BitLocker). Leave empty for no gate.
WORKSPACE_PASSPHRASE=

# ── Optional AI assistance (leave blank = the apps make no AI calls) ──────────
# The apps can draft text for you (DPIA risk narratives, breach notifications,
# negotiation explanations) using an AI ENGINE OF YOUR CHOICE. Two switches must
# BOTH be on: this engine config, AND an administrator enabling the AI posture
# inside each app (recorded with their name — it starts Off everywhere).
#
# Pick ONE recipe:
#
# 1) Fully local (nothing ever leaves this computer):
#      docker compose --profile ai up -d
#      docker compose exec ollama ollama pull qwen2.5:7b-instruct
#    then set:
#      LLM_GATEWAY_URL=http://ollama:11434
#      LLM_MODEL_ALIAS=qwen2.5:7b-instruct
#
# 2) Groq (US cloud, fast + cheap; enable Zero Data Retention in their console):
#      LLM_GATEWAY_URL=https://api.groq.com/openai
#      LLM_GATEWAY_KEY=<your Groq API key>
#      LLM_MODEL_ALIAS=llama-3.3-70b-versatile
#
# 3) Scaleway Generative APIs (EU cloud, French datacenters). Create YOUR OWN
#    key in the Scaleway console under IAM & API keys (the secret key is the
#    bearer token):
#      LLM_GATEWAY_URL=https://api.scaleway.ai
#      LLM_GATEWAY_KEY=<your Scaleway secret key>
#      LLM_MODEL_ALIAS=qwen3.6-35b-a3b
#
# Any OpenAI-compatible endpoint works the same way.
LLM_GATEWAY_URL=
LLM_GATEWAY_KEY=
LLM_MODEL_ALIAS=

# Advanced (optional): posture-routed lanes. Serve a DIFFERENT engine per
# confidentiality lane — when an administrator picks "EU cloud" in an app, the
# _EU engine answers; "US cloud" -> _US; "Local" -> _LOCAL. Any lane without
# its own values falls back to the base engine above. Needs app images from
# 2026-07-17 or newer.
#   LLM_GATEWAY_URL_EU=      LLM_GATEWAY_KEY_EU=      LLM_MODEL_ALIAS_EU=
#   LLM_GATEWAY_URL_US=      LLM_GATEWAY_KEY_US=      LLM_MODEL_ALIAS_US=
#   LLM_GATEWAY_URL_LOCAL=   LLM_GATEWAY_KEY_LOCAL=   LLM_MODEL_ALIAS_LOCAL=

# ── Premium skills (nothing to do) ───────────────────────────────────────────
# Premium skills bought on the todo.law marketplace verify against a public key
# that is BUILT INTO the apps. Leave this empty; purchased skills work out of
# the box. Set it ONLY if todo.law ever announces a key rotation: paste the new
# PEM as a \n-escaped one-liner (an env file cannot hold a multiline value; the
# apps restore the newlines):
#   -----BEGIN PUBLIC KEY-----\nMCowBQ...==\n-----END PUBLIC KEY-----\n
SKILL_SIGNING_PUBLIC_KEY=
