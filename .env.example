# todo.law suite — prebuilt-image install (docker-compose.yml).
# Copy to .env, fill the values, then: docker compose up -d
#
# Apps:  DPO Central  http://localhost:8485
#        Dealroom     http://localhost:8486
#        AI Sentinel  http://localhost:8487

# Which release to run. Pin a version (e.g. v0.1.1) for a reproducible install;
# "latest" always pulls the newest published images.
TODOLAW_VERSION=latest

# Database passwords (any strong strings; they only live inside this stack).
DPO_DB_PASSWORD=
DEAL_DB_PASSWORD=
AIS_DB_PASSWORD=

# Session signing secret. Generate one: openssl rand -base64 32
NEXTAUTH_SECRET=

# Cross-app bridge (optional). Set the SAME strong string here to turn on the
# unified DPIA + AI-Act view between DPO Central and AI Sentinel. Leave empty to
# keep them independent. Generate: openssl rand -hex 24
BRIDGE_API_KEY=

# Only used by `./suite.sh backup` to encrypt backups (not needed for a plain
# `docker compose up`). Keep a copy — you need it to restore. Generate: openssl rand -base64 24
BACKUP_PASSPHRASE=

# ── Premium skills (optional) ────────────────────────────────────────────────
# To buy + install premium skills (contract wizards, DPIA/PIA assessments) from
# the todo.law storefront, set the storefront's SIGNING PUBLIC KEY here so the
# apps can verify a purchased .skill + its licence. Get it from todo.law; it is a
# PEM. An env file can't hold a multiline value, so paste it as a \n-escaped
# one-liner (the apps restore the newlines):
#   -----BEGIN PUBLIC KEY-----\nMCowBQ...==\n-----END PUBLIC KEY-----\n
# Leave empty and premium-skill installs will be rejected (safe default).
SKILL_SIGNING_PUBLIC_KEY=
